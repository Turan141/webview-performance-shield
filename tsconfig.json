{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"jsx": "react-jsx",
		"types": ["node"],
		"paths": {
			"webview-performance-shield": ["./src/index.ts"],
			"webview-performance-shield/react": ["./src/react.ts"],
			"webview-performance-shield/*": ["./src/*"]
		},
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"useDefineForClassFields": true,
		"noEmit": true
	},
	"include": ["src", "demo"],
	"exclude": ["dist", "node_modules"]
}
